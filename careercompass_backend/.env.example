# ══════════════════════════════════════════════════════════════════
# CareerCompass Backend — Environment Variables (Example)
# 
# HOW TO USE:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Replace every placeholder value with your actual credentials
#   3. Save .env and run: node scripts/migrate.js
#
# ⚠️ NEVER commit your .env file to version control!
# ══════════════════════════════════════════════════════════════════


# ── DATABASE (REQUIRED) ────────────────────────────────────────────
#
# Get a FREE database URL in 2 minutes:
#
# Option A — Neon.tech (recommended for beginners):
#   1. Go to https://neon.tech → Sign up free
#   2. Create project → Copy the connection string
#   3. Paste it below
#
# Option B — Supabase:
#   1. Go to https://supabase.com → New project
#   2. Settings → Database → Connection string → URI tab
#   3. Replace [YOUR-PASSWORD] in the URL and paste below
#
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require


# ── JWT SECRET (REQUIRED) ──────────────────────────────────────────
#
# A random secret — used to sign login tokens. Make it 40+ characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
JWT_SECRET=your_jwt_secret_key_here_minimum_40_characters_long_random_string
JWT_EXPIRES_IN=7d


# ── ANTHROPIC API KEY (REQUIRED for AI roadmaps) ──────────────────
#
# Get from: https://console.anthropic.com → API Keys → Create Key
# Starts with: sk-ant-...
#
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_API_KEY_HERE


# ── SERVER ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development


# ── FRONTEND URL (for CORS) ───────────────────────────────────────
# URL where your HTML file is served (for CORS)
# Local: http://localhost:5500  or  http://127.0.0.1:5500
# Deployed: https://your-vercel-url.vercel.app
#
FRONTEND_URL=http://localhost:5500


# ── MARKET REFRESH (OPTIONAL) ─────────────────────────────────────
MARKET_REFRESH_ENABLED=false
MARKET_REFRESH_CRON=30 20 * * 6


# ── ADMIN (OPTIONAL) ──────────────────────────────────────────────
ADMIN_EMAILS=your-email@example.com